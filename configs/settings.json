{
  "workbench.colorTheme": "Tokyo Night Storm",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.editor.empty.hint": "hidden",
  "workbench.startupEditor": "none",
  "workbench.activityBar.location": "hidden",
  "workbench.sideBar.location": "right",
  "workbench.secondarySideBar.defaultVisibility": "hidden",

  // ==== EDITOR ====
  "editor.formatOnSave": false,
  "editor.wordWrap": "on",
  "editor.cursorBlinking": "expand",
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.guides.bracketPairs": true,
  "editor.minimap.enabled": false,
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.matchBrackets": "never",
  "editor.glyphMargin": true,
  "editor.fontLigatures": false,
  "editor.fontVariations": false,

  // ==== TERMINAL ====
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.fontFamily": "'Cascadia Code', 'Courier New', monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.drawBoldTextInBrightColors": true,
  "terminal.integrated.minimumContrastRatio": 7,
  "terminal.integrated.gpuAcceleration": "off",
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "docker-desktop"
  ],

  // ==== VENTANA ====
  "window.titleBarStyle": "custom",
  "window.controlsStyle": "default",
  "window.systemColorTheme": "dark",
  "window.autoDetectColorScheme": false,
  "window.newWindowProfile": "Predeterminado",

  // ==== CUSTOMIZE UI ====
  "customizeUI.animations": true,
  "customizeUI.listRowHoverAnimation": true,
  "customizeUI.activityBar": "bottom",
  "customizeUI.statusBar": "hidden",

  // ==== VIBRANCY ====
  "vibrancy.enabled": true,
  "vibrancy.theme": "acrylic",
  "vibrancy.effect": "acrylic",
  "vibrancy.opacity": 0.6,

  // ==== ANIMACIONES ====
  "animations.Enabled": true,
  "animations.Focus-Dimming-Mode": "Everything But Editor and Terminal",
  "animations.Install-Method": "Custom CSS and JS",

  // ==== ARCHIVOS & EXPLORER ====
  "files.autoSave": "afterDelay",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.compactFolders": false,

  // ==== GIT ====
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.graph.minimap.enabled": false,

  // ==== LANGUAGES ====
  "javascript.updateImportsOnFileMove.enabled": "always",
  "python.analysis.typeCheckingMode": "basic",
  "python.languageServer": "Pylance",
  "C_Cpp.autocompleteAddParentheses": true,

  // ==== LIVE SERVER ====
  "liveServer.settings.donotShowInfoMsg": true,
  "liveServer.settings.port": 5500,
  "liveServer.settings.root": "/src",

  // ==== COPILOT ====
  "github.copilot.advanced": {
    "authProvider": "github"
  },
  "github.copilot.nextEditSuggestions.enabled": true,

  // ==== SEGURIDAD ====
  "security.workspace.trust.untrustedFiles": "open",

  // ==== INDENT RAINBOW ====
  "indentRainbow.indicatorStyle": "light",
  "indentRainbow.lightIndicatorStyleLineWidth": 1,
  "indentRainbow.colors": [
    "rgba(255,255,64,0.3)",
    "rgba(127,255,127,0.3)",
    "rgba(255,127,255,0.3)",
    "rgba(79,236,236,0.3)"
  ],

  // ==== HIGHLIGHT ON COPY ====
  "highlight-on-copy.backgroundColor": "rgba(255, 0, 0, 0.3)",
  "highlight-on-copy.highlightBorder": "1px solid red",
  "highlight-on-copy.duration": 150,
  "highlight-on-copy.revealInExplorer": true,

  // ==== MATERIAL ICON THEME ====
  "material-icon-theme.folders.theme": "specific",
  "material-icon-theme.activeIconPack": "react_redux",

  // ==== MSSQL ====
  "mssql.connectionGroups": [
    {
      "name": "ROOT",
      "id": "ROOT"
    }
  ],
  "mssql.connections": [],

  // ==== OTRAS CONFIGURACIONES ====
  "workbench.colorCustomizations": {},
  "code-runner.runInTerminal": true,
  "vscode_custom_css.imports": [
    "file:///c:/Users/La TryHard/.vscode/extensions/brandonkirbyson.vscode-animations-2.0.7/dist/updateHandler.js"
  ],
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.docx": "default"
  },
  "workbench.settings.applyToAllProfiles": []
}